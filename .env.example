# Repo Agent Swarm - Environment Variables
# Copy this file to .env.local and fill in the values

# Claude Code uses your local authentication (Max plan or API key)
# If using API key mode, set:
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: Override the default model
# CLAUDE_MODEL=sonnet

# Authentication (Google OAuth)
# Create credentials at https://console.cloud.google.com/apis/credentials
# AUTH_SECRET=your-random-secret-here
# AUTH_GOOGLE_ID=your-google-oauth-client-id
# AUTH_GOOGLE_SECRET=your-google-oauth-client-secret

# Optional: Restrict login to specific email domains (comma-separated, empty = no restriction)
# ALLOWED_EMAIL_DOMAINS=company.com,example.com

# Optional: GitHub App integration (for importing private repos from orgs)
# GITHUB_APP_ID=123456
# GITHUB_PRIVATE_KEY=/path/to/your-app.pem  # PEM file path (recommended)
# GITHUB_PRIVATE_KEY="-----BEGIN RSA..."     # or PEM content directly
